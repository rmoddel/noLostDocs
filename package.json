{
  "name": "nolostdocs",
  "version": "0.1.0",
  "private": true,
  "overrides": {
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "npm run dev -w @nolostdocs/web",
    "dev:web-next": "npm run dev -w @nolostdocs/web",
    "dev:mobile": "npm run dev -w @nolostdocs/mobile",
    "build:web": "npm run build -w @nolostdocs/web",
    "build:web-next": "npm run build -w @nolostdocs/web",
    "lint": "npm run lint -ws --if-present",
    "typecheck": "npm run typecheck -ws --if-present"
  }
}
